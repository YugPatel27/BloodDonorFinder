<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme – uses Material3 with NO action bar (we draw our own) -->
    <style name="Base.Theme.BloodDonor" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary color = Red -->
        <item name="colorPrimary">@color/red_primary</item>
        <item name="colorPrimaryDark">@color/red_dark</item>
        <item name="colorAccent">@color/red_primary</item>
        <!-- Background = White -->
        <item name="android:windowBackground">@color/white</item>
        <item name="android:statusBarColor">@color/red_dark</item>
    </style>

    <!-- App theme (applied to whole app via Manifest) -->
    <style name="Theme.BloodDonor" parent="Base.Theme.BloodDonor" />

    <!-- Splash Screen Theme (shown before the app loads) -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_blood_logo</item>
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <item name="postSplashScreenTheme">@style/Theme.BloodDonor</item>
    </style>

    <!-- Toolbar style – red background, white text -->
    <style name="RedToolbar" parent="Widget.AppCompat.Toolbar">
        <item name="android:background">@color/red_primary</item>
        <item name="android:theme">@style/ThemeOverlay.AppCompat.Dark.ActionBar</item>
    </style>

    <!-- Button style – rounded red button with white text -->
    <style name="RedButton" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/red_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Outline Button – white with red border -->
    <style name="OutlineButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/red_primary</item>
        <item name="android:textColor">@color/red_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>