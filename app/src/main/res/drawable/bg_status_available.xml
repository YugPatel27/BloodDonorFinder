<?xml version="1.0" encoding="utf-8"?>
<!-- Green pill badge – shown when a donor is "Available" -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#E8F5E9" /><!-- very light green -->
    <stroke android:width="1dp" android:color="@color/green_available" />
    <corners android:radius="20dp" /><!-- high radius = pill shape -->
</shape>
