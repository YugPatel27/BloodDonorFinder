<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_login.xml – Login screen layout
  Structure:
    ScrollView (allows scrolling on small screens)
      LinearLayout (vertical stack of all UI elements)
        - Logo + App name at top
        - Email field
        - Password field
        - Login button
        - Register link
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- ─── Red header banner ─────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/bg_red_gradient"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <!-- Blood drop emoji as the header icon -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🩸"
                android:textSize="60sp" />

            <!-- App name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Blood Donor"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginTop="8dp" />

            <!-- Tagline -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="One Drop, Many Lives"
                android:textSize="14sp"
                android:textColor="#FFCDD2"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- ─── Login heading ──────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Welcome Back"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Login to your account"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="24dp" />

        <!-- ─── Email input ────────────────────────────────────── -->
        <!-- android:id – unique ID so Java can find this View by ID -->
        <!-- android:hint – placeholder text shown when field is empty -->
        <!-- android:inputType – tells keyboard what type of input to show -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Email Address"
            android:inputType="textEmailAddress"
            android:background="@drawable/bg_input_field"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:layout_marginBottom="14dp" />

        <!-- ─── Password input ────────────────────────────────── -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Password"
            android:inputType="textPassword"
            android:background="@drawable/bg_input_field"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:layout_marginBottom="24dp" />

        <!-- ─── Login Button ───────────────────────────────────── -->
        <!-- android:layout_width="match_parent" means full width -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Login"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:background="@drawable/bg_button_red"
            android:layout_marginBottom="16dp" />

        <!-- ─── Register link ─────────────────────────────────── -->
        <!-- Tapping this opens RegisterActivity -->
        <TextView
            android:id="@+id/tvRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Don't have an account? Register"
            android:textColor="@color/red_primary"
            android:textSize="14sp"
            android:padding="8dp" />

    </LinearLayout>
</ScrollView>
