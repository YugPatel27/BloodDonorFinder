<?xml version="1.0" encoding="utf-8"?>
<!--
  fragment_profile.xml – Profile tab
  Shows user info + quick links to sub-screens
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/grey_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ─── Profile Header (red background) ──────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_red_gradient"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:layout_marginTop="5dp">

            <!-- Circle avatar with initial/emoji -->
            <TextView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:id="@+id/tvAvatar"
                android:text="K"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="@color/red_primary"
                android:gravity="center"
                android:background="@color/white" />

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Keval Sheth"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"/>

            <TextView
                android:id="@+id/tvUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="keval@gmail.com"
                android:textColor="#FFCDD2"
                android:textSize="13sp" />

            <!-- Blood Group + Type badges inline -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/tvProfileBloodGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🩸 A+"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:background="#33FFFFFF"
                    android:paddingLeft="10dp" android:paddingRight="10dp"
                    android:paddingTop="3dp" android:paddingBottom="3dp"/>

                <TextView
                    android:id="@+id/tvUserType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  Donor"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:background="#33FFFFFF"
                    android:paddingLeft="10dp" android:paddingRight="10dp"
                    android:paddingTop="3dp" android:paddingBottom="3dp"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ─── Quick Links Card ──────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Donation History -->
                <LinearLayout
                    android:id="@+id/menuDonationHistory"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅  Donation History"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:layout_weight="1"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="22sp"
                        android:textColor="@color/red_primary"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/grey_light"/>

                <!-- My Donor Card -->
                <LinearLayout
                    android:id="@+id/menuDonorCard"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🪪  My Donor Card"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:layout_weight="1"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="22sp"
                        android:textColor="@color/red_primary"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/grey_light"/>

                <!-- Rewards -->
                <LinearLayout
                    android:id="@+id/menuRewards"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏆  Rewards &amp; Badges"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:layout_weight="1"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="22sp"
                        android:textColor="@color/red_primary"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/grey_light"/>

                <!-- Hospitals -->
                <LinearLayout
                    android:id="@+id/menuHospitals"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏥  Hospitals"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:layout_weight="1"/>
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="22sp"
                        android:textColor="@color/red_primary"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ─── Logout Button ─────────────────────────────────────── -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginLeft="12dp"
            android:layout_marginRight="12dp"
            android:layout_marginBottom="24dp"
            android:text="Logout"
            android:textColor="@color/white"
            android:background="@drawable/bg_button_red"/>

    </LinearLayout>
</ScrollView>
