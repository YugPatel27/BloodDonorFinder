<?xml version="1.0" encoding="utf-8"?>
<!-- item_badge_card.xml – a single badge shown in the Rewards grid/list -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Badge emoji (large, grey if not earned) -->
        <TextView
            android:id="@+id/tvBadgeEmoji"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="🏆"
            android:textSize="28sp"
            android:gravity="center"
            android:background="@drawable/bg_circle_red" />

        <!-- Badge info column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tvBadgeName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hero Donor"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/tvBadgeDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Donate blood 5 times"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Earned or Not indicator -->
        <TextView
            android:id="@+id/tvBadgeStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅"
            android:textSize="22sp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
