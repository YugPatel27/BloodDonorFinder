<?xml version="1.0" encoding="utf-8"?>
<!--
  item_donor_card.xml – A single donor's card shown in the donor search list.
  Each card shows: Name, Blood Group badge, Distance, Availability pill, Call button.
  This layout is REPEATED for every donor in the RecyclerView.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Avatar circle: shows first letter of donor's name -->
        <TextView
            android:id="@+id/tvDonorAvatar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text="R"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:background="@color/red_primary" />

        <!-- Info column (name, blood group, distance) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <!-- Donor name -->
            <TextView
                android:id="@+id/tvDonorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rahul Sharma"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <!-- Blood group badge (small pill) -->
            <TextView
                android:id="@+id/tvDonorBloodGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A+"
                android:textSize="12sp"
                android:textColor="@color/red_dark"
                android:textStyle="bold"
                android:background="@drawable/bg_blood_group_badge"
                android:paddingLeft="8dp" android:paddingRight="8dp"
                android:paddingTop="2dp" android:paddingBottom="2dp"
                android:layout_marginTop="4dp" />

            <!-- Distance from user -->
            <TextView
                android:id="@+id/tvDonorDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 1.2 km away"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Right side: Availability + Call button -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Availability status pill -->
            <TextView
                android:id="@+id/tvDonorStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Available"
                android:textSize="11sp"
                android:textColor="@color/green_available"
                android:background="@drawable/bg_status_available"
                android:paddingLeft="8dp" android:paddingRight="8dp"
                android:paddingTop="3dp" android:paddingBottom="3dp"
                android:layout_marginBottom="8dp" />

            <!-- Call button -->
            <Button
                android:id="@+id/btnCallDonor"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="📞 Call"
                android:textSize="12sp"
                android:textColor="@color/white"
                android:background="@drawable/bg_button_red"
                android:paddingLeft="12dp"
                android:paddingRight="12dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
