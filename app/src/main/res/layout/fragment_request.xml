<?xml version="1.0" encoding="utf-8"?>
<!--
  fragment_request.xml – Blood Requests tab
  Shows list of current blood requests, with a FAB to add a new one
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/grey_light">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/red_primary"
        android:padding="16dp"
        android:layout_marginTop="5dp"
        android:orientation="vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Blood Requests"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Post and view urgent blood requests"
            android:textColor="#FFCDD2"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- RecyclerView for requests list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRequests"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerLayout"
        android:padding="8dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp" />
    <!-- paddingBottom=80dp so the FAB doesn't cover the last item -->

    <!-- FAB = Floating Action Button – the red + button to post a new request -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddRequest"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="20dp"
        android:backgroundTint="@color/red_primary"
        android:contentDescription="Post Request"
        app:srcCompat="@android:drawable/ic_input_add"
        app:tint="@color/white" />

</RelativeLayout>
